#!/usr/bin/env bash
cd "$(dirname "$0")"
case "${1:-}" in
  setup)     python -m agent.wizard ;;
  run)       python -m agent.main ;;
  eval)      python -m agent.main --force-eval ;;
  dashboard) python -m streamlit run dashboard/app.py ;;
  *)
    echo ""
    echo "  ⚡  LLM Drift Tracker"
    echo ""
    echo "  drift setup        run the setup wizard"
    echo "  drift run          start the autonomous polling agent"
    echo "  drift eval         force-run evals for all monitored bots now"
    echo "  drift dashboard    launch the Streamlit dashboard"
    echo ""
    ;;
esac
